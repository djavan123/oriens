# ─────────────────────────────────────────────────────────────
# DESENVOLVIMENTO (local, SQLite)
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/oriens.db
# SECRET_KEY=qualquer-coisa-em-dev
# DEBUG=true
# COOKIE_SECURE=false
# AI_ENABLED=false
# AI_PROVIDER=null

# ─────────────────────────────────────────────────────────────
# PRODUÇÃO (VPS, PostgreSQL) — copie para .env e ajuste
# ─────────────────────────────────────────────────────────────

# A senha em DATABASE_URL DEVE ser igual a POSTGRES_PASSWORD.
DATABASE_URL=postgresql+asyncpg://oriens:TROQUE_ESSA_SENHA@db:5432/oriens
POSTGRES_PASSWORD=TROQUE_ESSA_SENHA

# Gere com: openssl rand -hex 32
SECRET_KEY=TROQUE_POR_UMA_CHAVE_ALEATORIA_LONGA

DEBUG=false
COOKIE_SECURE=true

# IA (opcional)
AI_ENABLED=false
AI_PROVIDER=null
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Telegram (opcional) — habilita lembretes E captura (SCRIPT 13).
# Crie um bot no @BotFather e pegue seu chat_id (ex.: via @userinfobot).
# Com isto preenchido, mensagens enviadas ao bot (apenas do TELEGRAM_CHAT_ID)
# viram capturas na caixa de entrada via long polling. Sem isto, só o popup funciona.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
